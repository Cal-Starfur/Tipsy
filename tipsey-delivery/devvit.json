{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "tipsey-delivery",
  "post": {
    "entrypoints": {
      "default": {
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "marketingAssets": {
    "icon": "assets/icon.png"
  },
  "server": {},
  "menu": {
    "items": [
      {
        "label": "[tipsey-delivery] New Post",
        "description": "Create a new tipsey-delivery post.",
        "location": "subreddit",
        "endpoint": "/internal/on/menu/new-post"
      },
      {
        "label": "[tipsey-delivery] Migrate All-Time to Cumulative",
        "description": "One-time: switches the all-time board from best-run to a running total, seeded from each player's current best run. Safe to re-run — only takes effect once.",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/on/menu/migrate-alltime-cumulative"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/on/app/install"
  },
  "scheduler": {
    "tasks": {
      "daily-post-check": {
        "endpoint": "/internal/scheduler/daily-post-check",
        "cron": "*/15 * * * *"
      },
      "deleted-user-sweep": {
        "endpoint": "/internal/scheduler/deleted-user-sweep",
        "cron": "0 8 * * 0"
      }
    }
  },
  "scripts": {
    "dev": "npm run watch"
  },
  "dev": {
    "subreddit": "tipsey_delivery_dev"
  }
}



