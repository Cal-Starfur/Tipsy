{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "tipsey-delivery",
  "post": {
    "entrypoints": {
      "default": {
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "marketingAssets": {
    "icon": "assets/icon.png"
  },
  "server": {},
  "menu": {
    "items": [
      {
        "label": "[tipsey-delivery] New Post",
        "description": "Create a new tipsey-delivery post.",
        "location": "subreddit",
        "endpoint": "/internal/on/menu/new-post"
      },
      {
        "label": "[tipsey-delivery] Backfill All-Time from Today",
        "description": "One-time utility: copies today's runs into the all-time board. Safe to re-run.",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/on/menu/backfill-alltime"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/on/app/install"
  },
  "scheduler": {
    "tasks": {
      "daily-post-check": {
        "endpoint": "/internal/scheduler/daily-post-check",
        "cron": "*/15 * * * *"
      }
    }
  },
  "scripts": {
    "dev": "npm run watch"
  },
  "dev": {
    "subreddit": "tipsey_delivery_dev"
  }
}


